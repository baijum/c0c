#use <conio>
int fib_iter(int n)
//@requires n >= 0;
{
  if (n <= 1) return n;

  int a = 0;
  int b = 1;
  for (int i = 2; i <= n; i++) {
    int tmp = a + b;
    a = b;
    b = tmp;
  }
  return b;
}

int fib_rec(int n)
//@requires n >= 0;
{
  if (n <= 1) return n;
  return fib_rec(n - 1) + fib_rec(n - 2);
}

int main() {
  for (int i = 0; i < 10; i++) {
    if (i > 0) print(" ");
    printint(fib_iter(i));
  }
  println("");

  //@assert fib_iter(10) == 55;
  //@assert fib_rec(10) == 55;

  printint(fib_iter(20));
  println("");

  printint(fib_rec(10));
  println("");

  return 0;
}
