#use <conio>
#use <string>

void swap(int[] a, int i, int j) {
  int tmp = a[i]; a[i] = a[j]; a[j] = tmp;
}

void bubble_sort(int[] a, int n) {
  for (int i = 0; i < n; i++) {
    for (int j = 0; j < n - i - 1; j++) {
      if (a[j] > a[j + 1]) { swap(a, j, j + 1); }
    }
  }
}

bool is_sorted(int[] a, int n) {
  for (int i = 0; i < n - 1; i++) {
    if (a[i] > a[i + 1]) return false;
  }
  return true;
}

int main() {
  int[] arr = alloc_array(int, 5);
  arr[0] = 5; arr[1] = 3; arr[2] = 8; arr[3] = 1; arr[4] = 4;
  printint(is_sorted(arr, 5) ? 1 : 0);
  println("");
  bubble_sort(arr, 5);
  printint(is_sorted(arr, 5) ? 1 : 0);
  println("");
  for (int i = 0; i < 5; i++) {
    printint(arr[i]);
    if (i < 4) { print(" "); }
  }
  println("");
  println(string_join("Hello", " C0!"));
  return 0;
}
