int main() {
  int x = 10;

  if (x > 5) {
    printint(1);
  } else {
    printint(0);
  }
  println("");

  if (x == 10) {
    printint(1);
  }
  println("");

  int sum = 0;
  int i = 1;
  while (i <= 10) {
    sum += i;
    i++;
  }
  printint(sum);
  println("");

  int prod = 1;
  for (int j = 1; j <= 5; j++) {
    prod *= j;
  }
  printint(prod);
  println("");

  int count = 0;
  for (int k = 0; k < 20; k++) {
    if (k % 2 == 0) count++;
    if (k == 15) break;
  }
  printint(count);
  println("");

  int cmp = (x > 5) ? 99 : 0;
  printint(cmp);
  println("");

  printint(true && false ? 1 : 0);
  println("");

  printint(true || false ? 1 : 0);
  println("");

  return 0;
}
