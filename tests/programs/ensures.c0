#use <conio>

int abs(int x)
//@requires true;
//@ensures \result >= 0;
{
  if (x < 0) return -x;
  return x;
}

int sum(int[] a, int n)
//@requires n == \length(a);
//@ensures \result >= 0;
{
  int s = 0;
  for (int i = 0; i < n; i++) {
    s += a[i];
  }
  if (s < 0) return -s;
  return s;
}

int main() {
  printint(abs(-42));
  println("");
  printint(abs(7));
  println("");

  int[] a = alloc_array(int, 3);
  a[0] = 10;
  a[1] = 20;
  a[2] = 30;
  printint(sum(a, 3));
  println("");

  return 0;
}
